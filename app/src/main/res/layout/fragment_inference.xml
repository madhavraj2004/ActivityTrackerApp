<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FA"
    android:paddingBottom="80dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Title ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity Inference"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="16dp"/>

        <!-- ── Step 1: Pick CSV ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step 1 — Select recorded CSV"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickCsv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📂  Pick CSV File"
                    app:cornerRadius="10dp"/>

                <TextView
                    android:id="@+id/txtFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No file selected"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Step 2: Run Inference ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Step 2 — Run batch inference (window = 60 rows)"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRunInference"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶  Run Inference"
                    android:enabled="false"
                    app:cornerRadius="10dp"/>

                <!-- Progress bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/inferenceProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:indeterminate="false"
                    app:trackThickness="8dp"
                    android:visibility="gone"/>

                <!-- Model / run status -->
                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading model…"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginTop="8dp"/>

                <!-- Accuracy summary -->
                <TextView
                    android:id="@+id/txtSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Results preview ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Output columns"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Timestamp  |  Actual_Label  |  Predicted_Label  |  Confidence  |  Latency(ms)  |  Valid"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Step 3: Export ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾  Export Inference CSV"
            android:enabled="false"
            android:layout_marginTop="4dp"
            app:cornerRadius="10dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>